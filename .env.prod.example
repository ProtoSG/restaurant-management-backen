# =============================================================================
# Production Environment Variables — TEMPLATE (committed)
# Copy to .env.prod and fill in real values before running start-prod.sh
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# Database
DB_URL=jdbc:postgresql://localhost:5432/ddbb_restaurant_management_prod
DB_USERNAME=
DB_PASSWORD=

# Security — generate with: openssl rand -base64 64
JWT_SECRET_KEY=

# Server
PORT=8081

# CORS
FRONTEND_URL=
