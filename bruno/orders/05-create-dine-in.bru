meta {
  name: Create Order - DINE_IN
  type: http
  seq: 5
}

post {
  url: {{base_url}}/orders
  body: json
  auth: none
}

body:json {
  {
    "tableId": {{table_id}},
    "type": "DINE_IN",
    "customerName": null
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.orderCode: isDefined
  res.body.status: eq "CREATED"
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("order_id", res.body.id);
  }
}
