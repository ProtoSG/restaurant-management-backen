meta {
  name: Create Order - TAKEAWAY
  type: http
  seq: 6
}

post {
  url: {{base_url}}/orders
  body: json
  auth: none
}

body:json {
  {
    "tableId": null,
    "type": "TAKEAWAY",
    "customerName": "Carlos López"
  }
}

assert {
  res.status: eq 201
  res.body.status: eq "CREATED"
  res.body.type: eq "TAKEAWAY"
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("order_id", res.body.id);
  }
}
