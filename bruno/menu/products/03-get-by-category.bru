meta {
  name: Get Products By Category
  type: http
  seq: 3
}

get {
  url: {{base_url}}/products/categories/{{category_id}}
  body: none
  auth: none
}

params:query {
  page: 0
  size: 20
}

assert {
  res.status: eq 200
  res.body.content: isArray
  res.body.totalElements: isDefined
  res.body.totalPages: isDefined
}
