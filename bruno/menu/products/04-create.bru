meta {
  name: Create Product (ADMIN only)
  type: http
  seq: 4
}

post {
  url: {{base_url}}/products
  body: json
  auth: none
}

body:json {
  {
    "name": "Ceviche Especial",
    "price": 25.00,
    "categoryId": {{category_id}}
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("product_id", res.body.id);
  }
}
